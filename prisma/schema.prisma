generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id                    Int       @id @default(autoincrement())
  userCode              String    @unique
  firstName             String
  lastName              String
  documentType          String
  documentNumber        String    @unique
  birthDate             DateTime
  gender                String?
  phone                 String
  email                 String?
  address               String?
  occupation            String?
  allergies             String?
  currentMedications    String?
  systemicDiseases      String?
  surgeries             String?
  pregnant              Boolean   @default(false)
  smoker                Boolean   @default(false)
  medicalNotes          String?
  lastDentalVisit       DateTime?
  reasonForConsultation String?
  previousTreatments    String?
  brushingFrequency     String?
  flossing              Boolean   @default(false)
  bleedingGums          Boolean   @default(false)
  bruxism               Boolean   @default(false)
  dentalNotes           String?
  isInPain              Boolean   @default(false)
  painLevel             Int       @default(0)
  painLocation          String?
  painDuration          String?
  painTrigger           String?
  painDescription       String?
  takesMedication       Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  treatmentPlans        TreatmentPlan[]
}

model TreatmentPlan {
  id                   Int      @id @default(autoincrement())
  patientId            Int
  tooth                String
  diagnosisProcedure   String
  unitCost             Float
  observations         String?
  plannedDate          DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}
